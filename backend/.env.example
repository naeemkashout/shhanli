# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/kashout
# Optional fallback for local development when Atlas is unreachable
MONGODB_URI_FALLBACK=mongodb://127.0.0.1:27017/kashout

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRE=30d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Email Configuration (for password reset)
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@kashout.com

# Admin Configuration
ADMIN_EMAIL=admin@kashout.com
ADMIN_PASSWORD=Admin@123456

# Paymera eGate (test integration)
PAYMERA_EGATE_BASE_URL=https://egate-t.paymera.cc
PAYMERA_EGATE_USERNAME=bastaline
PAYMERA_EGATE_PASSWORD=bastaline@123
PAYMERA_EGATE_TERMINAL_ID=14740238
PAYMERA_EGATE_LANG=en
PAYMERA_EGATE_CALLBACK_URL=https://example.com/payment/callback
PAYMERA_EGATE_TRIGGER_URL=https://example.com/payment/trigger

# Syriatel E_Payment integration
SYRIATEL_EPAYMENT_BASE_URL=https://example.com
SYRIATEL_EPAYMENT_USERNAME=your-merchant-username
SYRIATEL_EPAYMENT_PASSWORD=your-merchant-password
SYRIATEL_EPAYMENT_MERCHANT_MSISDN=9639xxxxxxxx
# Override these if Syriatel uses different endpoint paths in your deployment
SYRIATEL_EPAYMENT_GET_TOKEN_PATH=/getToken
SYRIATEL_EPAYMENT_PAYMENT_REQUEST_PATH=/paymentRequest
SYRIATEL_EPAYMENT_PAYMENT_CONFIRMATION_PATH=/paymentConfirmation
SYRIATEL_EPAYMENT_RESEND_OTP_PATH=/resendOTP